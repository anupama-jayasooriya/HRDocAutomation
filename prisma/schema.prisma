generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id             String     @id @default(cuid())
  fullName       String
  email          String     @unique
  phone          String
  nic            String
  position       String
  department     String
  employmentType String
  salary         Float
  startDate      DateTime
  companyRepName String
  createdAt      DateTime   @default(now())

  documents      Document[]
  emailLogs      EmailLog[]
}

model Document {
  id           String    @id @default(cuid())
  candidateId  String
  documentType String
  fileUrl      String
  generatedAt  DateTime  @default(now())

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model EmailLog {
  id          String    @id @default(cuid())
  candidateId String
  emailStatus String
  sentAt      DateTime  @default(now())

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}